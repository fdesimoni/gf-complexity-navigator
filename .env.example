# Helbling LLM Router (optional, for chart rendering with Anthropic API)
# Leave empty to use the direct Anthropic cloud API (requires ANTHROPIC_API_KEY)
ANTHROPIC_BASE_URL=https://api-chat.helbling.ch/llm

# Anthropic API Key (required if using direct API)
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: use a different token name for router auth
# ANTHROPIC_AUTH_TOKEN=...

# Optional: specify which model to use for chart spec interpretation
# ANALYSIS_LLM_MODEL=claude-sonnet-4-6
